@page
@model LibreCare.Pages.Profiles.IndexModel

<h1>Profiles</h1>

<p>
    <a asp-page="Create">Create New Profile</a>
</p>

<table>
    <thead>
    <tr>
        <th>Name</th>
        <th>Birth Date</th>
        <th>Active</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var profile in Model.Profiles)
    {
        <tr>
            <td>@profile.Name</td>
            <td>@profile.BirthDate</td>
            <td>
                @if (profile.IsActive)
                {
                    <strong>Active</strong>
                }
                else
                {
                    <form method="post" asp-page-handler="SetActive">
                        <input type="hidden" name="id" value="@profile.Id" />
                        <button type="submit">Set Active</button>
                    </form>
                }
            </td>
            <td>
                <a asp-page="Edit" asp-route-id="@profile.Id">Edit</a>

                <form method="post" asp-page-handler="Delete" style="display:inline;">
                    <input type="hidden" name="id" value="@profile.Id" />
                    <button type="submit" onclick="return confirm('Are you sure you want to delete this profile?');">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
